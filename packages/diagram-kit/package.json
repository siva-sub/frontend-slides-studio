{
  "name": "@slides-studio/diagram-kit",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "scripts": { "build": "tsc -p tsconfig.json", "typecheck": "tsc -p tsconfig.json --noEmit", "test": "vitest run", "gallery": "pnpm --filter @slides-studio/protocol build && tsx scripts/generate-gallery.ts", "check:gallery": "pnpm --filter @slides-studio/protocol build && tsx scripts/generate-gallery.ts --check" },
  "dependencies": { "@slides-studio/protocol": "workspace:*" },
  "devDependencies": { "tsx": "^4.19.4", "typescript": "^5.8.3", "vitest": "^3.2.3" }
}
