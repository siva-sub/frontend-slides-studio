{
  "name": "@slides-studio/runtime",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.types.json && esbuild src/index.ts --bundle --format=iife --global-name=SlidesStudioRuntime --target=es2020 --minify --outfile=dist/slides-studio-runtime.iife.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": { "@slides-studio/protocol": "workspace:*" },
  "devDependencies": { "happy-dom": "^18.0.1", "typescript": "^5.8.3", "vitest": "^3.2.3" }
}
