{
  "name": "@slides-studio/style-registry",
  "version": "0.1.0",
  "type": "module",
  "description": "Browser-safe typed registry of licensed style/layout and recipe resources with deterministic layout queries and recipe scaffolding.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "generate": "tsx scripts/generate.ts",
    "check:generated": "tsx scripts/generate.ts --check",
    "build": "tsx scripts/generate.ts && tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@slides-studio/protocol": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3",
    "zod": "^3.25.56"
  }
}
