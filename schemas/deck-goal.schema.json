{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/siva-sub/frontend-slides-studio/schemas/deck-goal.schema.json",
  "title": "DeckGoalV1",
  "type": "object",
  "required": ["schemaVersion", "id", "title", "slides"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "renderMode", "role"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "renderMode": { "enum": ["html", "visual-master"] },
          "role": { "enum": ["cover", "agenda", "section", "content", "comparison", "data", "diagram", "quote", "closing", "other"] },
          "layout": { "type": "string" },
          "props": { "type": "object" },
          "diagram": { "type": "object" },
          "visualMaster": { "type": "object" },
          "motion": { "type": "object" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": true
}
