{
  "version": "2",
  "style_id": "clean-tech-blue",
  "style_name": "清爽科技蓝 / Stripe-grade Blue",
  "global_style": "对标 Stripe / Linear / Notion 官网与 Pitch 路演 deck 的高级蓝白风：纯白背景 + 克制蓝调 + 大留白 + 精致网格。比传统 McKinsey 蓝更现代、更产品化，比 SaaS landing 更适合长篇内容。适合融资路演、商业计划书、企业战略汇报。 背景：纯白 #FFFFFF，绝不使用深色背景；可在大块区域用极淡冰蓝 #F4F7FF 区分。 主蓝：Stripe 紫蓝 #635BFF 或皇家蓝 #1E40AF，作为标题、强调数字、品牌色块。 次蓝：浅蓝 #93C5FD 用于柔性",
  "theme": {
    "primary": "",
    "accent": [],
    "background": "",
    "fonts": {
      "title": "",
      "body": ""
    }
  },
  "layouts": [
    {
      "id": "cover-hero-composition",
      "page_type": "cover",
      "summary": "左 60% 放主标题（深墨黑超大粗体，2-3 行内）+ 下方副标题（中蓝标准字重）+ 底部 1 行 tagline；右 40% 放一个浅蓝色简洁 3D 几何体（棱柱、球、抽象 SaaS 图形），透明度 30%，绝不喧宾夺主。顶部或底部一条 4px 高的蓝色渐变细带作为品牌锚点。",
      "visual_signature": "封面主视觉",
      "content_capacity": {
        "title": "8-18 个中文字符",
        "subtitle": "1 行短副标题",
        "meta": "可选 1-2 行日期、作者或机构"
      },
      "best_for": [
        "cover",
        "opening",
        "brand title"
      ],
      "avoid_for": [
        "dense content",
        "table",
        "multi-metric data"
      ],
      "variation_tags": [
        "cover",
        "hero",
        "title-focus"
      ],
      "external_image_slots": [],
      "reuse_friendly": false,
      "reuse_reason": "该页面形态视觉锚点较强，建议同一 deck 只使用一次。",
      "json_schema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 2,
            "maxLength": 24,
            "description": "主标题"
          },
          "subtitle": {
            "type": "string",
            "minLength": 0,
            "maxLength": 56,
            "description": "副标题"
          },
          "meta": {
            "type": "string",
            "minLength": 0,
            "maxLength": 40,
            "description": "日期、作者或机构"
          }
        },
        "required": [
          "title"
        ],
        "additionalProperties": false
      }
