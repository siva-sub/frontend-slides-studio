{
  "version": "2",
  "style_id": "hand-sketch",
  "style_name": "手绘草稿 / Hand Sketch",
  "global_style": "对标 Mike Rohde 的 Sketchnote、Visual Thinking 工作坊的白板手绘风：暖米色纸张 + 手写体标题 + 不规则方框/箭头 + 马克笔高亮色 + 简笔小图标。带温度、显思考过程、有设计冲动感。适合工作坊、产品早期 brainstorming、培训、产品设计 review。 背景：暖米白 #FBF7EE 或淡黄稿纸 #F8F1DA，叠加可见的纸张纹理 + 极淡 4mm 方格线（5% 透明度，类似无印良品本子）。 主线：深炭灰 #2A2A2A（不是纯黑），所有线条手绘感 -- 略微抖动、",
  "theme": {
    "primary": "",
    "accent": [],
    "background": "",
    "fonts": {
      "title": "",
      "body": ""
    }
  },
  "layouts": [
    {
      "id": "cover-hero-composition",
      "page_type": "cover",
      "summary": "中央放主标题（巨大手写体，可有装饰下划线或被圈起），上方或下方画一个手绘相框（不规则圆角矩形、四角带\"装订钉\"或\"胶带\"装饰）；旁边散布手绘装饰：箭头、星号、感叹号气泡、灯泡图标；底部一行小手写字签名。",
      "visual_signature": "封面主视觉",
      "content_capacity": {
        "title": "8-18 个中文字符",
        "subtitle": "1 行短副标题",
        "meta": "可选 1-2 行日期、作者或机构"
      },
      "best_for": [
        "cover",
        "opening",
        "brand title"
      ],
      "avoid_for": [
        "dense content",
        "table",
        "multi-metric data"
      ],
      "variation_tags": [
        "cover",
        "hero",
        "title-focus"
      ],
      "external_image_slots": [],
      "reuse_friendly": false,
      "reuse_reason": "该页面形态视觉锚点较强，建议同一 deck 只使用一次。",
      "json_schema": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string",
            "minLength": 2,
            "maxLength": 24,
            "description": "主标题"
          },
          "subtitle": {
            "type": "string",
            "minLength": 0,
            "maxLength": 56,
            "description": "副标题"
          },
          "meta": {
            "type": "string",
            "minLength": 0,
            "maxLength": 40,
            "description": "日期、作者或机构"
          }
        },
        "required": [
          "title"
        ],
        "additionalProperties": false
      }
    },
